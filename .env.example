# Edge Device Configuration (NVIDIA Jetson Nano)
# Copy to .env and fill in values

# Required: Controller credentials (from cloud dashboard)
EDGE_CONTROLLER_ID=ctrl_xxxxxxxx
EDGE_API_KEY=ek_xxxxxxxx

# Cloud API URL
EDGE_API_URL=https://api.anpr.cloud

# Plate Recognizer Stream On-Premise (both required)
# Get from: https://app.platerecognizer.com/service/stream/
# Note: License is tied to device hardware fingerprint
PLATE_RECOGNIZER_TOKEN=your-plate-recognizer-api-token
PLATE_RECOGNIZER_LICENSE_KEY=your-license-key

# Jetson JetPack version tag for Plate Recognizer image
# JetPack 4.6.x: latest | JetPack 5.x: r35 | JetPack 6.x: r36
JETPACK_TAG=latest

# Optional overrides
# EDGE_WEBHOOK_PORT=8001
# EDGE_RELAY_PIN=18
# EDGE_DB_PATH=data/edge.db
# EDGE_LOG_LEVEL=INFO
